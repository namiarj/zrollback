#!/bin/sh

#
# Global
#
name=zrollback
tmp="/tmp/$name"

#
# Functions
#
clean ()
{
  rm $tmp 2> /dev/null
}

error ()
{
  echo "$name: $*" >&2
  exit 1
}

guard ()
{
  if [ $? -ne 0 ]; then
    error "$*" 
  fi
}

setup ()
{
  if bsddialog --version > /dev/null; then
    d=bsddialog
  else
    d=dialog
  fi
}

tmpcheck ()
{
  if [ -e $tmp ]; then
    error "$tmp exists"
  fi
}

zdestroy ()
{
  $d --yesno --default-button No "Destroy $snap?" 0 0
  if [ $? -eq 0 ]; then
    zfs destroy $snap
    guard "zfs destroy failed"
  fi
}

zlist ()
{
  snaps=`zfs list -H -t snapshot -o name`
  guard "zfs list failed"
  menu="$d --ok-label Property --extra-button --extra-label Rollback --help-button --help-label Destroy --no-tags --menu Snapshots 0 0 0"
  for snap in $snaps
  do
    menu="$menu $snap $snap"
  done
  tmpcheck
  $menu 2> $tmp
  case $? in
  0)
    snap=`more $tmp`
    zprop
    ;;
  2)
    snap=`more $tmp | tail -c +5`
    zdestroy
    ;;
  3)
    snap=`more $tmp`
    zrollback
    ;;
  *)
    exit
  esac
  clean
}

zprop ()
{
  prop=`zfs get -H -o property,value all $snap` 
  guard "zfs get failed"
  text=`printf "$snap\n$prop"`
  $d --msgbox "$text" 0 0
}

zrollback ()
{
  $d --yesno --default-button No "Rollback $snap?" 0 0
  if [ $? -eq 0 ]; then
    zfs rollback $snap
    guard "zfs rollback failed" 
  fi
}

#
# Main
#
setup
trap "clean; exit" INT TERM HUP EXIT
while true
do
  zlist
done
