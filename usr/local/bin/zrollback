#!/bin/sh

#
# Global
#
d="bsddialog"
progname=${0##*/}

#
# Functions
#
cleanup ()
{
	rm $tmpfile 2>/dev/null
}

error ()
{
	echo "$progname: $*" >&2
	exit 1
}

gen_tmp ()
{
	tmpfile="/tmp/$progname"."`awk 'BEGIN {srand();printf "%d\n", rand() * 10^10}'`"
}

list_snaps ()
{
	snaps=`zfs list -t snapshot -o name -H`
	cmd="$d --ok-label Props --extra-button --extra-label Rollback --help-button --help-label Destroy --no-tags --menu Snapshots 20 46 40"
	for snap in $snaps
	do
		cmd="$cmd $snap `echo $snap`"
	done
	gen_tmp
	$cmd 2> $tmpfile
	case $? in
	0)
		# Props 
		snap=`more $tmpfile`
		zfs_props
		;;
	2)
		# Destroy
		snap=`more $tmpfile | tail -c +5`
		zfs_destroy
		;;
	3)
		# Rollback
		snap=`more $tmpfile`
		zfs_rollback
		;;
	*)
		exit 0
	esac
	cleanup
}

zfs_destroy ()
{
	$d --default-button No --yesno "Destroy $snap?" 7 50 
	case $? in
	0)
		zfs destroy $snap
		;;
	esac
}

zfs_props ()
{
	props=`zfs get -o property,value all $snap` 
	$d --msgbox "$props" 24 64
}

zfs_rollback ()
{
	$d --default-button No --yesno "Rollback $snap?" 7 50
	case $? in
	0)
		zfs rollback $snap
		;;
	esac
}

#
# Main
#
main ()
{
	trap "cleanup; exit" INT TERM HUP EXIT
	while true
	do
		list_snaps
  	done
}

main $@
